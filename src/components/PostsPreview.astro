---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

export interface Props {
  posts: CollectionEntry<'posts'>[];
  limit?: number;
}
const { posts, limit } = Astro.props;
const list = typeof limit === 'number' ? posts.slice(0, limit) : posts;
---

<div class="preview-root container-fluid">
  <div class="row">
    <div class="title col-md-12 col-lg-5">
      <p class="small-title">posts.</p>
      <h2 class="big-title">Find<br class="hidden-mobile" /> latest stories</h2>
    </div>
    <div class="posts-list col-md-12 col-lg-6">
      {list.map((post) => <PostCard post={post} parallax />)}
    </div>
  </div>
</div>

<style>
  .preview-root {
    max-width: 1640px;
    margin-bottom: var(--sp-8);
  }
  @media only screen and (max-width: 768px) {
    .preview-root { margin-bottom: var(--sp-6); }
  }

  .title { margin-right: var(--sp-6); }
  @media only screen and (max-width: 768px) {
    .title { margin-bottom: var(--sp-4); }
  }

  .small-title {
    font-size: var(--fs-3);
    color: var(--light-90);
    font-family: var(--font-title) !important;
    margin-bottom: 1.5rem;
  }
  @media only screen and (max-width: 768px) {
    .small-title { font-size: var(--fs-2-5) !important; }
  }
  @media only screen and (max-width: 576px) {
    .small-title { font-size: var(--fs-1-5) !important; }
  }

  @media only screen and (max-width: 1024px) { .big-title { font-size: var(--fs-4) !important; } }
  @media only screen and (max-width: 768px) { .big-title { font-size: var(--fs-3-5) !important; } }
  @media only screen and (max-width: 576px) { .big-title { font-size: var(--fs-2-5) !important; } }

  .posts-list { margin-left: auto; margin-right: auto; }
</style>

<script>
  import '../scripts/parallax.js';
</script>
