---
export interface Props {
  title: string;
  created: string;
}
const { title, created } = Astro.props;
---

<div class="post-header-root container-fluid">
  <div class="row justify-center">
    <div class="col-lg-6">
      <img class="logo" src="/logo-dark.svg" alt="gceico logo" />
      <h1 class="title">{title}</h1>
      <small class="date">{created}</small>
    </div>
    <div class="col-sm-8">
      <div class="separator">&nbsp;</div>
    </div>
  </div>
</div>

<style>
  .post-header-root {
    max-width: 1640px;
    margin-bottom: var(--sp-6);
    text-align: center;
  }
  .logo {
    display: inline-block;
    margin-top: var(--sp-6);
    height: var(--sp-7);
    width: var(--sp-7);
    margin-bottom: var(--sp-5);
  }
  .title { color: var(--shade-90); }
  @media only screen and (max-width: 768px) {
    .title { font-size: var(--fs-3) !important; }
  }
  @media only screen and (max-width: 576px) {
    .title { font-size: var(--fs-2) !important; }
  }
  .date { color: var(--shade-50); }

  .separator {
    width: 100%;
    height: var(--sp-4);
    position: relative;
    z-index: 0;
    border: 2px solid var(--light-50);
    margin-top: var(--sp-5);
    margin-bottom: var(--sp-5);
  }
  @media only screen and (max-width: 576px) {
    .separator { margin-bottom: 0; }
  }
  .separator:before {
    width: 100%;
    content: '';
    z-index: -1;
    height: 100%;
    display: block;
    position: absolute;
    bottom: calc(-1 * var(--sp-2));
    right: calc(-1 * var(--sp-2));
    background: var(--color-secondary);
  }
</style>
