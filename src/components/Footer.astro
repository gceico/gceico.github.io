---
import { site } from '../data/site';

export interface Props {
  postFooter?: boolean;
}
const { postFooter = false } = Astro.props;
const logoSrc = postFooter ? '/logo-dark.svg' : '/logo.svg';
---

<div class:list={['footer-root', 'container-fluid', { post: postFooter }]}>
  <img class="bg-logo" src={logoSrc} alt="" />
  <div class="separator">&nbsp;</div>
  <div class="row">
    <div class="col-md-6 col-lg-4">
      <h5 class="title">Email</h5>
      <p class="paragraph">
        <a href={`mailto:${site.author.email}`}>{site.author.email}</a>
      </p>
    </div>
    <div class="col-md-6 col-lg-4">
      <h5 class="title">Connect</h5>
      <div class="social-media">
        <ul>
          {site.social.map((s) => (
            <li><a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col copyright">
      <small>baked with ❤️ 2026 gceico.me</small>
    </div>
  </div>
</div>

<style>
  .footer-root {
    position: relative;
    max-width: 1640px;
    padding-top: var(--sp-8);
    padding-bottom: var(--sp-6);
  }
  @media only screen and (max-width: 768px) {
    .footer-root { padding-top: var(--sp-6); }
  }

  .bg-logo {
    top: 50%;
    left: 100%;
    width: 50vw;
    height: 50vw;
    opacity: 0.1;
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 0;
    pointer-events: none;
  }
  @media only screen and (max-width: 768px) {
    .bg-logo { top: 30%; }
  }
  @media only screen and (max-width: 576px) {
    .bg-logo { top: 15%; left: 70%; }
  }

  .separator {
    width: 100%;
    height: var(--sp-4);
    position: relative;
    z-index: 0;
    border: 2px solid var(--light-50);
    margin-bottom: var(--sp-5);
  }
  .separator:before {
    width: 100%;
    content: '';
    z-index: -1;
    height: 100%;
    display: block;
    position: absolute;
    bottom: calc(-1 * var(--sp-2));
    right: calc(-1 * var(--sp-2));
    background: var(--color-secondary);
  }

  .social-media ul {
    margin: 0;
    padding: 0;
    display: flex;
    list-style-type: none;
  }
  .social-media li { margin-right: var(--sp-4); margin-bottom: 0; }
  @media only screen and (max-width: 768px) {
    .social-media ul { flex-wrap: wrap; }
  }

  .copyright { padding-top: var(--sp-7); }

  /* post (light) footer overrides */
  .post .title { color: var(--shade-90); }
  .post .copyright { color: var(--shade-70); }
  .post .copyright small { color: var(--shade-70); }
  .post .social-media li a:hover,
  .post .paragraph a:hover { color: var(--color-primary); transition: color 0.25s ease-in; }
</style>
