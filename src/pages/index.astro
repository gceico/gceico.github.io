---
import { getCollection } from 'astro:content';
import { site } from '../data/site';
import { getSortedPosts } from '../lib/posts';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHeader from '../components/HomeHeader.astro';
import PostsPreview from '../components/PostsPreview.astro';
import Portfolios from '../components/Portfolios.astro';
import CV from '../components/CV.astro';
import FAQ from '../components/FAQ.astro';

const posts = await getSortedPosts();
const portfolios = (await getCollection('portfolios')).sort(
  (a, b) => a.data.order - b.data.order
);
const experiences = await getCollection('experiences');

const title = `${site.author.fullName}, ${site.heading}`;
const description =
  'Gabriel Ceicoschi is a Senior Software Engineer building AI agents and founder of Aibl.to AI workshops in Tilburg. Blog, portfolio, and CV.';

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.author.fullName,
  jobTitle: site.heading,
  url: site.url,
  image: new URL('/avatar-new.jpg', site.url).href,
  address: { '@type': 'PostalAddress', addressLocality: 'Tilburg', addressCountry: 'NL' },
  sameAs: [
    'https://www.linkedin.com/in/gceico/',
    'https://x.com/gceico',
    'https://aibl.to/author/gabriel/',
    'https://github.com/gceico',
    'https://indiepa.ge/gceico',
    'https://aibl.to',
  ],
  knowsAbout: [
    'AI agents',
    'Agentic workflows',
    'AI Workshops',
    'Retrieval-augmented generation (RAG)',
    'TypeScript',
    'React',
    'UI/UX',
  ],
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.title,
  url: site.url,
  author: { '@type': 'Person', name: site.author.fullName },
  inLanguage: 'en',
};

const organization = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Aibl.to',
  url: 'https://aibl.to',
  founder: { '@type': 'Person', name: site.author.fullName },
  areaServed: { '@type': 'Country', name: 'Netherlands' },
  description:
    'Hands-on AI workshops for teams in the Netherlands. Teams build AI agents on their real workflows and own what they build.',
};

const portfolioList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${site.author.fullName} — Portfolio`,
  itemListElement: portfolios.map((p, i) => ({
    '@type': 'CreativeWork',
    position: i + 1,
    name: p.data.title,
    description: p.data.description,
  })),
};

const faqs = [
  {
    question: 'What does Gabriel Ceicoschi do?',
    answer:
      'Gabriel is a Senior Software Engineer who builds AI agents, focused on making AI accessible through user experience, privacy, and security.',
  },
  {
    question: 'What is Aibl.to?',
    answer:
      "Aibl.to is Gabriel's own venture: hands-on AI workshops where teams in the Netherlands build AI agents on their real workflows. 300+ professionals trained across 20+ companies, including ASML and LocHal Tilburg.",
  },
  {
    question: 'Where is Gabriel based?',
    answer: 'Tilburg, Netherlands.',
  },
  {
    question: 'Does Gabriel take freelance or consulting work?',
    answer:
      'Yes. Freelance web/app projects (WordPress, e-commerce, dashboards) alongside AI agent and workshop work — see the Portfolio and CV sections above.',
  },
  {
    question: 'What tools does Gabriel build?',
    answer:
      'Open-source developer tooling for the Claude Code ecosystem, such as the "Claude, make it rain" spend tracker and Aihar.app, plus AI agent platforms and RAG-based tools.',
  },
];

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  path="/"
  structuredData={[person, website, organization, portfolioList, faq]}
>
  <header>
    <HomeHeader />
  </header>
  <main>
    <PostsPreview posts={posts} limit={3} />
    <Portfolios portfolios={portfolios} />
    <CV experiences={experiences} />
    <FAQ faqs={faqs} />
  </main>
</BaseLayout>
