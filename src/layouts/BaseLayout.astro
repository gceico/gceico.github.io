---
import { site } from '../data/site';
import Footer from '../components/Footer.astro';
import '../styles/theme.css';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  /** Path (e.g. "/posts/foo") — canonical + og:url are built from site.url + this. */
  path: string;
  /** Absolute-or-root path to the share image. Defaults to /thumbnail.jpg */
  image?: string;
  /** Light layout (blog posts) vs dark layout (home / posts list). */
  postLayout?: boolean;
  ogType?: 'website' | 'article';
  /** JSON-LD object or array of objects. */
  structuredData?: Record<string, any> | Record<string, any>[] | null;
}

const {
  title,
  description,
  path,
  image = '/thumbnail.jpg',
  postLayout = false,
  ogType = 'website',
  structuredData = null,
} = Astro.props;

// Pages build as directories (trailing-slash URLs) — keep canonical/og:url on
// the resolved form so they never point at a 301.
const normalizedPath = path.endsWith('/') ? path : `${path}/`;
const canonical = new URL(normalizedPath, site.url).href;
const ogImage = new URL(image, site.url).href;
const jsonLd = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#e25b4a" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.author.fullName} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Tinos:wght@400;700&family=Varela+Round&display=swap"
    />

    <!-- Feed -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={site.title}
      href={new URL('/rss.xml', site.url).href}
    />

    <link rel="icon" href="/ico/fav1.png" id="fav" />

    {jsonLd.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
  </head>
  <body>
    <div class:list={['root', { post: postLayout }]}>
      <slot />
      <footer>
        <Footer postFooter={postLayout} />
      </footer>
    </div>

    <!-- Animated favicon (replaces react-favicon) -->
    <script is:inline>
      (function () {
        var icons = ['/ico/fav1.png', '/ico/fav2.png', '/ico/fav3.png'];
        var i = 0;
        var link = document.getElementById('fav');
        if (link) {
          setInterval(function () {
            i = (i + 1) % icons.length;
            link.href = icons[i];
          }, 500);
        }
      })();
    </script>
  </body>
</html>

<style>
  .root {
    overflow: hidden;
    background: var(--color-fill);
  }
  .root.post {
    background: var(--light-100);
  }
</style>
